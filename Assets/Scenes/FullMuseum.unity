  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: workshop_card_03
  roomID: workshop
  cardTitle: The Economics of Thread
  cardDescription: his workshop represents women's economic power in a society that
    restricted their public roles. The textiles produced here generated income that
    women controlled, giving them influence over household decisions. A skilled weaver
    could earn enough to contribute significantly to family expenses or save for
    her daughter's dowry. The workshop was a space where women's labor translated
    directly into economic value, challenging the notion that Ottoman women were
    merely confined to domestic invisibility. Their hands held threads, but also
    negotiating power.
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
