  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: kitchen_card_01
  roomID: kitchen
  cardTitle: The Copper Treasury
  cardDescription: 'The gleaming copper vessels displayed here were a family''s pride
    and a woman''s tools of mastery. Each pot, pan, and kettle had a specific purpose
    passed down through generations: the long-handled cezve for brewing coffee, the
    wide tava for baking, the rounded kazan for cooking pilaf. Copper''s excellent
    heat distribution made it ideal for Albanian cuisine, while its beauty elevated
    cooking from mere necessity to craft. These vessels were polished religiously,
    their shine reflecting not just light but a family''s self-respect.'
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
