  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: kitchen_card_03
  roomID: kitchen
  cardTitle: Preservation and Seasons
  cardDescription: "Notice the ceramic jars and wooden barrels? Before refrigeration,
    families relied on ancient preservation methods. Summer's abundance\u2014peppers,
    tomatoes, cucumbers\u2014was pickled in brine or vinegar to sustain the household
    through winter. Fruit was dried in the sun, meats were cured with salt, cheese
    was stored in oil. The kitchen was not just where meals were prepared, but where
    families literally captured summer's bounty to survive mountain winters. This
    room held the knowledge that separated survival from starvation."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
