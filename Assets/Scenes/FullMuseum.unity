  cardTitle: The Hearth's Warmth
  cardDescription: "The chimney you see was essential for survival during Berat's
    cold winters. Families would huddle around the mangal\u2014a metal brazier filled
    with hot coals\u2014placed safely beneath the chimney hood. The rising smoke
    carried not just warmth, but also the scent of burning wood and the comfort of
    home. Winter evenings in this room meant the family gathered close, repairing
    tools, telling stories, and maintaining the bonds that held households together
    through harsh mountain winters."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
