  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: archive_card_02
  roomID: archive
  cardTitle: Wedding as Theater
  cardDescription: "The wedding photographs reveal elaborate multi-day celebrations
    that united not just two people, but two families and their broader communities.
    Notice the intricate embroidery on the bride's costume\u2014months of work by
    female relatives, each stitch a prayer for her future. The guests' formal poses
    reflect the solemnity of the occasion. These weren't merely parties; they were
    cultural performances where every detail\u2014from the dowry display to the ritual
    dances\u2014reinforced social bonds and transmitted tradition to the next generation.
    Weddings were living textbooks."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
