  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: bedroom_card_03
  roomID: bedroom
  cardTitle: The Dowry Closet
  cardDescription: "This wooden closet held far more than clothes\u2014it was the
    repository of family heritage. A bride's dowry would be carefully stored here:
    hand-embroidered linens, copper cookware, jewelry, and textiles that represented
    years of preparation. The closet's contents told the story of a family's social
    standing and a woman's industriousness. Mothers would open these doors with their
    daughters, teaching them which items to treasure, which to use daily, and which
    to pass to the next generation. "
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
