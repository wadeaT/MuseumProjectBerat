  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: guest_room_card_03
  roomID: guest_room
  cardTitle: Coffee, Raki, and Conversation
  cardDescription: "The ritual of guest reception followed precise codes: Turkish
    coffee was served in small cups on ornate trays, accompanied by sweets. For closer
    friends, raki\u2014the anise-flavored spirit\u2014flowed freely. Conversations
    in this room ranged from business negotiations to marriage arrangements to political
    discussions. The decorative niches in the walls held precious objects\u2014copper
    coffeepots, silver trays, fine glassware\u2014that were brought out only for
    honored guests, transforming hospitality into an art form that bound communities
    together."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
