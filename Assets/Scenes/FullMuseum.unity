  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: kitchen_card_02
  roomID: kitchen
  cardTitle: Fire and Patience
  cardDescription: "The traditional hearth in this kitchen required constant attention
    and skill. Women tended fires from dawn until evening, managing different zones
    of heat for various cooking tasks. There were no thermometers or timers\u2014just
    experience passed from mother to daughter about when coals glowed at the perfect
    temperature for bread, when flames should leap for quick frying, when embers
    should smolder for slow stews. The kitchen was a woman's laboratory where science
    met tradition, and meals became expressions of love and expertise."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
