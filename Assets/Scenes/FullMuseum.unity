  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: bedroom_card_01
  roomID: bedroom
  cardTitle: The Family Sanctuary
  cardDescription: "This modest room with its two mattresses and simple furnishings
    was the private heart of family life. Unlike the guest room with its elaborate
    decoration, the bedroom prioritized function and intimacy. The mattresses\u2014stuffed
    with wool and covered in hand-woven textiles\u2014were rolled and stored in the
    closet during the day, transforming the room into a multipurpose space. At night,
    it became a sanctuary where parents told stories to children and passed down
    oral traditions in whispered conversations by candlelight."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
