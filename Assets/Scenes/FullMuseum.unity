  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: workshop_card_01
  roomID: workshop
  cardTitle: The Loom's Song
  cardDescription: The wooden loom standing before you was the economic engine of
    many Berat households. Women spent countless hours at this machine, transforming
    raw wool or cotton into fabric that clothed the family, furnished the home, and
    could be sold for income. The rhythmic clack-clack-clack of the shuttle passing
    through threads created a soundtrack to domestic life. Young girls learned at
    their mothers' sides, their small hands gradually mastering the coordination
    required to create tight, even weaves. The loom was both tool and teacher.
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
