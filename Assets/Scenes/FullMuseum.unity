  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: guest_room_card_01
  roomID: guest_room
  cardTitle: The Theater of Hospitality
  cardDescription: "This guest room, the most elaborately decorated space in the
    house, was a stage for performing social status and cultural values. Every element\u2014from
    the painted ceiling to the built-in divans\u2014announced to visitors that they
    had entered a home of refinement and honor. In Ottoman Albanian culture, hospitality
    was not merely kindness; it was a sacred duty. A family's reputation rested on
    their treatment of guests, making this room far more than mere decoration\u2014it
    was an investment in social survival."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
