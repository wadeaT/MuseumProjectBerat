  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: archive_card_01
  roomID: archive
  cardTitle: Frozen Moments
  cardDescription: "These photographs capture Albanian life in the late 19th and
    early 20th centuries\u2014weddings in traditional dress, village gatherings,
    family portraits. Before photography, such memories lived only in oral tradition,
    subject to the distortions of time and retelling. These images are windows into
    a world where every garment, gesture, and gathering carried deep cultural meaning.
    The faces staring back at us are your ancestors, their formal poses concealing
    vibrant personalities, their traditional costumes representing thousands of hours
    of skilled handwork now mostly vanished."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
