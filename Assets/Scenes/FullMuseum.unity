--- !u!114 &1968495315
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1968495313}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: workshop_card_02
  roomID: workshop
  cardTitle: Patterns of Identity
  cardDescription: "The geometric patterns woven into Albanian textiles were far
    more than decoration\u2014they were a visual language. Each region, even each
    family, had distinctive motifs. A woman could identify a textile's origin by
    examining its borders and central medallions. These patterns connected weavers
    to their ancestors, as daughters recreated designs their great-grandmothers had
    invented. In a world where few could read or write, these visual vocabularies
    preserved cultural memory and announced identity. A rug was a signature, a declaration:
    \"This is who we are.\""
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
