  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: archive_card_03
  roomID: archive
  cardTitle: Community Memory
  cardDescription: "Photos of village gatherings show the \xE7arshia (marketplace)
    and public squares where men conducted business and discussed politics, while
    women's gatherings happened in courtyards and homes. These images capture the
    parallel social worlds of Ottoman Albanian life\u2014men in the public sphere,
    women in the domestic\u2014yet both equally vital to community survival. The
    traditional clothing, architecture, and body language in these photos tell stories
    that words cannot. They remind us that before globalization homogenized the world,
    every village had its distinct visual identity."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
