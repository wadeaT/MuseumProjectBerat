  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: guest_room_card_02
  roomID: guest_room
  cardTitle: The Mahfil's Secret
  cardDescription: "Notice the elevated platform\u2014the mahfil\u2014attached to
    the wall? This architectural feature allowed women to observe guest receptions
    while remaining separated by a decorative screen or curtain. Ottoman society
    prescribed separate spheres for men and women in formal settings, yet the mahfil
    reveals how architecture created spaces for women's presence and agency. From
    this elevated position, the lady of the house could ensure proper hospitality
    was extended while maintaining the appearance of seclusion expected by tradition."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
