  - m_Id: 34776998064128
    m_Localized: "Kitchen Storage\r\nChest\r"
    m_Metadata:
      m_Items: []
  - m_Id: 35109287604224
    m_Localized: "A wooden chest used to store flour,\r\ngrains, and kitchen supplies.
      It kept food\r\ndry, protected, and ready for daily\r\ncooking.\r"
    m_Metadata:
      m_Items: []
  - m_Id: 35341484273664
    m_Localized: Stone Mortar and Pestle
    m_Metadata:
      m_Items: []
  - m_Id: 36060685774848
    m_Localized: 'A heavy stone mortar used with a

      wooden pestle for grinding
      grains, herbs,

      and spices in the traditional Ottoman

      kitchen.'
    m_Metadata:
      m_Items: []
  - m_Id: 36191208321024
    m_Localized: "Clay Water Jug\r"
    m_Metadata:
      m_Items: []
  - m_Id: 36482620174336
    m_Localized: 'A handmade clay jug used for storing

      and carrying water.
      Its multiple handles

      allow easier lifting and pouring.'
    m_Metadata:
      m_Items: []
  - m_Id: 36614455537664
    m_Localized: Weigher
    m_Metadata:
      m_Items: []
  - m_Id: 36987601793024
