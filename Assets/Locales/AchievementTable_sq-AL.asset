  m_TableData:
  - m_Id: 50656555008
    m_Localized: ARRITJET TUAJA
    m_Metadata:
      m_Items: []
  - m_Id: 134400028672
    m_Localized: Kthehu Pas
    m_Metadata:
      m_Items: []
  - m_Id: 788480765952
    m_Localized: "P\xEBrfundo"
    m_Metadata:
      m_Items: []
  - m_Id: 261907971682304
    m_Localized: "Zbulimi i Par\xEB"
    m_Metadata:
      m_Items: []
  - m_Id: 261955539283968
    m_Localized: "Ju sapo gjet\xEBt kart\xEBn e par\xEB t\xEB fshehur! Sekrete t\xEB
      m\xEBtejshme t\xEB muzeut ju presin."
    m_Metadata:
      m_Items: []
  - m_Id: 262008064552960
    m_Localized: Eksplorues Kureshtar
    m_Metadata:
      m_Items: []
  - m_Id: 262097503891456
    m_Localized: "Keni zbuluar tre karta! Kureshtja juaj po ju \xE7on m\xEB thell\xEB
      n\xEB historin\xEB e Beratit."
    m_Metadata:
      m_Items: []
  - m_Id: 262137454637056
    m_Localized: "K\xEBrkues i P\xEBrkushtuar"
    m_Metadata:
      m_Items: []
  - m_Id: 262193285017600
    m_Localized: "Gjasht\xEB karta t\xEB gjetura! Po zbuloni shtresat e jet\xEBs
      s\xEB familjes osmane."
    m_Metadata:
      m_Items: []
  - m_Id: 262253821407232
    m_Localized: "Studiues K\xEBmb\xEBngul\xEBs"
    m_Metadata:
      m_Items: []
  - m_Id: 262298415247360
    m_Localized: "N\xEBnt\xEB karta! Jeni n\xEB gjysm\xEBn e historis\xEB s\xEB muzeut."
    m_Metadata:
      m_Items: []
  - m_Id: 262662841544704
    m_Localized: "Kujdestar i Trash\xEBgimis\xEB"
    m_Metadata:
      m_Items: []
  - m_Id: 262770454802432
    m_Localized: "Pes\xEBmb\xEBdhjet\xEB karta! Tani jeni nj\xEB kujdestar i kujtes\xEBs
      kulturore t\xEB Beratit."
    m_Metadata:
      m_Items: []
  - m_Id: 262832358535168
    m_Localized: "Koleksioni i Plot\xEB"
    m_Metadata:
      m_Items: []
  - m_Id: 262866315620352
    m_Localized: "T\xEB gjitha 18 kartat u zbuluan! \xC7do histori e fshehur u zbulua."
    m_Metadata:
      m_Items: []
  - m_Id: 262925669216256
    m_Localized: "Zemra e Sht\xEBpis\xEB"
    m_Metadata:
      m_Items: []
  - m_Id: 262970569240576
    m_Localized: "Keni zbuluar sekretet e \"\xC7ardakut\", qendra shoq\xEBrore ku
      familjet mblidheshin, endnin dhe mir\xEBprisnin mysafir\xEB."
    m_Metadata:
      m_Items: []
  - m_Id: 263033920008192
    m_Localized: Streha e Familjes
    m_Metadata:
      m_Items: []
  - m_Id: 263171644174336
    m_Localized: "Keni eksploruar hap\xEBsir\xEBn private ku familjet gjenin ngroht\xEBsi,
      pushim dhe p\xEBrcillnin traditat gojore brez pas brezi."
    m_Metadata:
      m_Items: []
  - m_Id: 263227696852992
    m_Localized: "Mjesht\xEBr i Mikpritjes"
    m_Metadata:
      m_Items: []
  - m_Id: 263287583125504
    m_Localized: "Keni kuptuar artin e mikpritjes osmane ku arkitektura, dekorimi
      dhe rituali bashkoheshin p\xEBr t\xEB nderuar mysafir\xEBt."
    m_Metadata:
      m_Items: []
  - m_Id: 263331614928896
    m_Localized: "Trash\xEBgimi Kulinarie"
    m_Metadata:
      m_Items: []
  - m_Id: 263396798607360
    m_Localized: "Keni zbuluar mjetet dhe traditat e gatimit osman ku zjarri dhe
      bakri ishin p\xEBrb\xEBr\xEBsit kryesor t\xEB k\xEBsaj kulture."
    m_Metadata:
      m_Items: []
  - m_Id: 263425823191040
    m_Localized: "Trash\xEBgimia e Endjes"
    m_Metadata:
      m_Items: []
  - m_Id: 263472128307200
    m_Localized: "Keni m\xEBsuar artin e endjes tradicionale zanati q\xEB mbajti
      familjet, ruajti identitetin dhe u dha grave fuqi ekonomike."
    m_Metadata:
      m_Items: []
  - m_Id: 263592156704768
    m_Localized: "Ruajt\xEBs i Kujtes\xEBs"
    m_Metadata:
      m_Items: []
  - m_Id: 263646649102336
    m_Localized: "Keni d\xEBshmuar momentet e ngrira t\xEB historis\xEB shqiptare;
      fotografi q\xEB ruajn\xEB zakone, ceremoni dhe komunitete tashm\xEB t\xEB transformuara
      nga koha."
    m_Metadata:
      m_Items: []
  - m_Id: 263677921832960
    m_Localized: "Studiues i Jet\xEBs Osmane"
    m_Metadata:
      m_Items: []
  - m_Id: 263721676812288
    m_Localized: "Keni eksploruar \xE7do cep t\xEB muzeut dhe keni p\xEBrjetuar rr\xEBfimin
      e plot\xEB t\xEB jet\xEBs familjare n\xEB Beratin e epok\xEBs osmane. Tani
      jeni nj\xEB ruajt\xEBs i k\xEBsaj trash\xEBgimie kulturore!"
    m_Metadata:
      m_Items: []
  - m_Id: 269289099472896
    m_Localized: 'Kartat e mbledhura: {0}'
    m_Metadata:
      m_Items: []
  - m_Id: 269341901565952
    m_Localized: 'Stemat e zhbllokuara: {0}'
    m_Metadata:
      m_Items: []
  - m_Id: 269383915909120
    m_Localized: 'Karta e fundit e gjetur: {0}'
    m_Metadata:
      m_Items: []
  - m_Id: 269411162107904
    m_Localized: 'Stema e fundit e zhbllokuar: {0}'
    m_Metadata:
      m_Items: []
