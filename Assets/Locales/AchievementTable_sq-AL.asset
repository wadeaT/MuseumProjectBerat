  - m_Id: 269705971347456
    m_Localized: Dhoma e Gjumiit
    m_Metadata:
      m_Items: []
  - m_Id: 269752792363008
    m_Localized: "Dhoma e Mysafir\xEBve"
    m_Metadata:
      m_Items: []
  - m_Id: 269844182052864
    m_Localized: Kuzhina
    m_Metadata:
