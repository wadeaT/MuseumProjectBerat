  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: balcony_card_03
  cardTitle: Between Worlds
  cardDescription: "Notice how this balcony connects every room? Traditional Berat
    homes were designed with the \xE7ardak as the axis\u2014symbolically linking
    private family life with community obligations. From this very spot, you could
    reach the kitchen, the guest room (oda e mikut), and the women's quarters. The
    house itself was a miniature model of social harmony."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
