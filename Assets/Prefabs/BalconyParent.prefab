  m_Script: {fileID: 11500000, guid: 6324c5069e2ab2147aafea77a8cdfbd5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HiddenCard
  cardID: balcony_card_01
  cardTitle: The Heart of the Home
  cardDescription: "This balcony, called a '\xE7ardak' in Albanian, was the social
    center of traditional Berat homes. Families gathered here for meals, women wove
    textiles, and honored guests were welcomed with coffee and raki. The wooden railings
    allowed residents to observe street life below while maintaining privacy\u2014a
    clever feature of Ottoman-era architecture."
  detectionRadius: 3
  requiresDirectLook: 1
  interactionKey: 101
  hintEffect: {fileID: 0}
  idleColor: {r: 1, g: 0.6, b: 0.2, a: 1}
  activeColor: {r: 1, g: 0.8, b: 0, a: 1}
  discoverySound: {fileID: 0}
